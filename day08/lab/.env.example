# Day 08 Lab — RAG Pipeline
# Copy file này thành .env và điền API key

# === LLM Provider ===
# Chọn "openai" hoặc "gemini"
LLM_PROVIDER=openai

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=qwen2.5-coder:7b

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
EVAL_PROVIDER=openai
EVAL_FAITHFULNESS_MODEL=gpt-5.4-mini
EVAL_RELEVANCE_MODEL=gpt-5.4-mini
EVAL_COMPLETENESS_MODEL=gpt-5.4-mini

# OpenRouter (https://openrouter.ai/)
OPENROUTER_API_KEY=

# Google Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=

# Model mặc định
LLM_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash

# === Embedding ===
# Chọn "openai" hoặc "local" (sentence-transformers)
EMBEDDING_PROVIDER=local
CHROMA_API_KEY=
HUGGINGFACE_TOKEN=

# Model sentence-transformers nếu dùng local embedding
# LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
